# Optional: defaults to the directory that contains the `app` package
# BACKEND_ROOT=.

# Relative paths are resolved against BACKEND_ROOT (see app/config.py)
DATA_DIR=data
SIM_PROJECT_DIR=../microserviceSim
DB_PATH=data/sim_tasks.db
MVN_COMMAND=mvn
CORS_ORIGINS=["*"]
MAX_CONCURRENT_TASKS=5

# Replay JSONL parser cache: max tasks retained in RAM (LRU). <=0 = unlimited.
# REPLAY_PROCESSOR_CACHE_MAX=64

# Optional: simulation workload CSV directory (default datasources/ under BACKEND_ROOT)
# SOURCE_DATA_DIR=datasources
